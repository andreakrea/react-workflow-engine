{
  "name": "@workflow-engine/backend",
  "version": "1.0.0",
  "description": "Generic graph-based workflow engine — drop-in Node.js/Express/PostgreSQL package",
  "main": "index.js",
  "exports": {
    ".": "./index.js",
    "./migrations": "./migrations"
  },
  "files": [
    "index.js",
    "WorkflowEngine.js",
    "WorkflowHooksDispatcher.js",
    "router.js",
    "migrations",
    "knexfile.example.js"
  ],
  "keywords": [
    "workflow",
    "state-machine",
    "graph",
    "express",
    "knex",
    "postgresql"
  ],
  "license": "MIT",
  "peerDependencies": {
    "express": ">=4.0.0",
    "knex": ">=2.0.0",
    "pg": ">=8.0.0"
  },
  "devDependencies": {
    "express": "^4.18.0",
    "knex": "^3.1.0",
    "pg": "^8.11.0"
  },
  "scripts": {
    "migrate": "knex migrate:latest --knexfile knexfile.example.js"
  }
}
